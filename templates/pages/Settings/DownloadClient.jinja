{#def
    user: DetailedUser,
    downloadclient_base_url: str,
    downloadclient_username: str,
    downloadclient_password: str,
    downloadclient_category: str,
    downloadclient_categories: list[Category]
#}

<SettingsLayout user={{ user }} page="downloadclient" title="Settings - Download Client">
<js.AlpineJS />

<div class="flex flex-col gap-2">
    <h2 class="text-lg">
        Download Client
    </h2>

    <label for="downloadclient-base-url">
        Base URL
    </label>
    <form class="join w-full"
          hx-put="{{ base_url }}/settings/downloadclient/base-url"
          hx-disabled-elt="#downloadclient-base-url-button">
        <input id="downloadclient-base-url"
               name="base_url"
               type="url"
               value="{{ downloadclient_base_url }}"
               class="input join-item w-full"
               minlength="1"
               required />
        <button id="downloadclient-base-url-button" class="join-item btn">
            {% if downloadclient_base_url %}
                Update
            {% else %}
                Add
            {% endif %}
        </button>
    </form>

    <label for="downloadclient-username" class="pt-2">
        Username
    </label>
    <form class="join w-full"
          hx-put="{{ base_url }}/settings/downloadclient/username"
          hx-disabled-elt="#downloadclient-username-button">
        <input id="downloadclient-username"
               name="username"
               value="{{ downloadclient_username }}"
               class="input join-item w-full"
               minlength="1"
               required />
        <button id="downloadclient-username-button" class="join-item btn">
            {% if downloadclient_username %}
                Update
            {% else %}
                Add
            {% endif %}
        </button>
    </form>

    <label for="downloadclient-password" class="pt-2">
        Password
    </label>
    <form class="join w-full"
          hx-put="{{ base_url }}/settings/downloadclient/password"
          hx-disabled-elt="#downloadclient-password-button">
        <input id="downloadclient-password"
               name="password"
               type="password"
               {% if downloadclient_password %}placeholder="●●●●●●●●●●●●●●●●●" {% endif %}
               class="input join-item w-full"
               minlength="1"
               required />
        <button id="downloadclient-password-button" class="join-item btn">
            {% if downloadclient_password %}
                Update
            {% else %}
                Add
            {% endif %}
        </button>
    </form>

    <label for="downloadclient-category" class="pt-2">
            Category
    </label>
    <form class="join w-full"
          hx-put="{{ base_url }}/settings/downloadclient/hx-category"
          hx-disabled-elt="#downloadclient-category-button">
        <select id="downloadclient-category" name="category" class="select join-item w-full">
            {% if not downloadclient_base_url %}
                <option disabled selected>
                    Enter URL first
                </option>
            {% elif not downloadclient_categories|length %}
                <option disabled selected>
                    No categories
                </option>
            {% else %}
            {% for category in downloadclient_categories %}
                <option value="{{ category.name }}"
                        {% if downloadclient_category==category.name %}selected{% endif %}>
                    {{ category.name }} - ({{ category.savePath }})
                </option>
            {% endfor %}
            {% endif %}
        </select>
        <button id="downloadclient-category-button" class="join-item btn">
            Save
        </button>
    </form>

    <div class="flex flex-col space-y-4 mt-4">
        <!-- Test Connection Section -->
        <div class="flex items-center gap-3">
            <button class="btn btn-primary btn-outline btn-sm gap-2 hover:btn-primary"
                    hx-get="{{ base_url }}/settings/downloadclient/test-connection"
                    hx-target="#connection-info"
                    hx-swap="innerHTML"
                    hx-indicator="#test-spinner">
                    <icons.Refresh />
                Test Connection
            </button>

            <!-- Loading Indicator -->
            <div id="test-spinner" class="htmx-indicator flex items-center gap-2">
                <span class="loading loading-spinner loading-sm"></span>
                <span class="text-sm text-base-content/70">Testing...</span>
            </div>
        </div>

        <!-- Connection Result Area -->
        <div id="connection-info" class="min-h-[60px] transition-all duration-300">
        </div>
    </div>

</div>
</SettingsLayout>
